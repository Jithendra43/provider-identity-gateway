# =============================================================================
#                     LOCAL DEVELOPMENT / docker-compose ONLY
# -----------------------------------------------------------------------------
# In AWS production these values come from Secrets Manager + SSM Parameter
# Store (see docs/SECRETS-INVENTORY.md and infra/terraform/modules/secrets/).
# Do NOT use this file as a template for prod deploys. Do NOT commit a real
# .env. The committed values below are placeholders / safe defaults.
# =============================================================================

# ===== Database =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tefca_gateway
POSTGRES_USER=tefca
POSTGRES_PASSWORD=change_me_in_production

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== OAuth2 / OIDC =====
OAUTH2_ISSUER_URI=https://your-idp.example.com
OAUTH2_AUDIENCE=tefca-gateway

# ===== AWS (local dev) =====
AWS_REGION=us-east-1
AWS_PROFILE=tefca-dev

# ===== TEFCA mTLS edge =====
# Mutual TLS between QHIN partners and the gateway. In compose the NGINX
# sidecar terminates TLS 1.3 on :8443 and forwards the verified cert in
# X-Client-Cert; in production the AWS ALB does the same.
TEFCA_MTLS_ENABLED=true
TEFCA_MTLS_STRICT=true
TEFCA_MTLS_KEYSTORE_PATH=
TEFCA_MTLS_KEYSTORE_PASSWORD=
TEFCA_MTLS_KEYSTORE_TYPE=PKCS12
TEFCA_MTLS_TRUSTSTORE_PATH=
TEFCA_MTLS_TRUSTSTORE_PASSWORD=
TEFCA_MTLS_TRUSTSTORE_TYPE=PKCS12
# How often the in-memory trust store is reloaded from
# ingress.partner_certificates (milliseconds). 5 minutes in prod.
TEFCA_MTLS_REFRESH_INTERVAL_MS=300000

# ===== TEFCA replay protection =====
# Redis-backed dedup on (jti, correlationId). MUST stay true outside test envs.
TEFCA_REPLAY_PROTECTION_ENABLED=true

# ===== TEFCA HMAC =====
# Outbound partner request signing key. Rotate on the standard cert cadence.
TEFCA_HMAC_SECRET=change_me_in_production

# ===== Rate limiting =====
RATE_LIMIT_RPM=100

# ===== Admin console =====
ADMIN_AUTH_MODE=mock
ADMIN_PASSWORD=change_me_in_production
OPERATOR_PASSWORD=change_me_in_production
AUDITOR_PASSWORD=change_me_in_production
ADMIN_COOKIE_SECURE=true
